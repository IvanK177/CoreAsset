# CoreAsset Environment Variables
# Copy this file to .env and fill in the values

# Database — Supabase PostgreSQL Connection String
DATABASE_URL="postgresql://postgres:[Core_128500!]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# GraphQL API URL (used by Next.js frontend)
NEXT_PUBLIC_GRAPHQL_API_URL="http://localhost:4000/graphql"