# CoreAsset Environment Variables
# Copy this file to .env and fill in the values

# Database — PostgreSQL Connection String (Supabase or local)
DATABASE_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Direct URL — Required by Prisma for migrations/push
# For Supabase: use the session pooler URL (port 5432, no pooler suffix)
# For local PostgreSQL: same as DATABASE_URL
DIRECT_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# GraphQL API URL (used by Next.js frontend)
NEXT_PUBLIC_GRAPHQL_API_URL="http://localhost:4000/graphql"