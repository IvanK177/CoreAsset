# ============================================================
# CoreAsset ITAM — Environment Variables Template
# ============================================================
# Public keys (Supabase URL, anon key) are included — they are safe to share.
# Secret keys (DATABASE_URL with password) have placeholders — fill them in:
#   • Local dev: copy this file to .env and replace placeholders with real values
#   • Production: add secrets only in Vercel → Settings → Environment Variables
#
# Vercel projects:
#   API:  https://vercel.com/ivank177s-projects/core-asset-api
#   Web:  https://core-asset-api.vercel.app/hardware
# ============================================================

# ---- Database (Supabase PostgreSQL) — SECRETS, do NOT commit real values ----
# Use Supavisor pooler (IPv4 compatible) instead of direct connection (IPv6 only)
# DATABASE_URL: transaction mode (port 6543) for app queries — pgbouncer=true disables prepared statements
# DIRECT_URL: session mode (port 5432) for Prisma migrations
DATABASE_URL=postgres://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgres://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ---- Supabase (public anon key — safe to publish) ----
NEXT_PUBLIC_SUPABASE_URL=...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable...

# ---- GraphQL API URL (public — safe to publish) ----
NEXT_PUBLIC_GRAPHQL_API_URL=http://localhost:4000/graphql

# ---- API Server Port ----
PORT=4000