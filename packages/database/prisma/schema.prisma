// CoreAsset ITAM — Prisma Schema
// Database: PostgreSQL (Supabase)
// Design: 3NF relational model with UUID primary keys

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// 1. Hardware Assets — Central registry of physical equipment
// ============================================
model HardwareAsset {
  id               String   @id @default(uuid()) @map("id")
  serialNumber     String   @unique @map("serial_number") @db.VarChar(100)
  name             String   @map("name") @db.VarChar(200)
  type             String   @map("type") @db.VarChar(50) // "desktop", "laptop", "monitor", "printer", "server"
  brand            String   @map("brand") @db.VarChar(100)
  model            String   @map("model") @db.VarChar(100)
  lifecycleState   String   @default("active") @map("lifecycle_state") @db.VarChar(20) // "active", "in_repair", "decommissioned", "in_storage", "disposed"
  purchaseDate     DateTime? @map("purchase_date") @db.Date
  warrantyEndDate  DateTime? @map("warranty_end_date") @db.Date
  discoveryMetadata Json?   @map("discovery_metadata") @db.JsonB
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  workplaces        Workplace[]
  installations     SoftwareInstallation[]
  faultIncidents    FaultHistoryIncident[]

  @@index([lifecycleState], map: "idx_hardware_lifecycle")
  @@index([serialNumber], map: "idx_hardware_serial")
  @@index([type], map: "idx_hardware_type")
  @@map("hardware_assets")
}

// ============================================
// 2. Users — Employee profiles
// ============================================
model User {
  id          String   @id @default(uuid()) @map("id")
  employeeId  String   @unique @map("employee_id") @db.VarChar(50)
  fullName    String   @map("full_name") @db.VarChar(200)
  email       String   @unique @map("email") @db.VarChar(255)
  department  String?  @map("department") @db.VarChar(100)
  position    String?  @map("position") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  workplaces Workplace[]

  @@index([fullName], map: "idx_user_fullname")
  @@index([email], map: "idx_user_email")
  @@index([department], map: "idx_user_department")
  @@map("users")
}

// ============================================
// 3. Workplaces — Linking asset to employee in a location
// ============================================
model Workplace {
  id          String   @id @default(uuid()) @map("id")
  name        String   @map("name") @db.VarChar(200)
  location    String?  @map("location") @db.VarChar(200)
  userId      String   @map("user_id")
  hardwareId  String   @map("hardware_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  user       User          @relation(fields: [userId], references: [id], onDelete: Restrict, map: "fk_workplace_user")
  hardware   HardwareAsset @relation(fields: [hardwareId], references: [id], onDelete: Restrict, map: "fk_workplace_hardware")

  @@index([userId], map: "idx_workplace_user")
  @@index([hardwareId], map: "idx_workplace_hardware")
  @@index([location], map: "idx_workplace_location")
  @@map("workplaces")
}

// ============================================
// 4. Software Catalog — Directory of approved software
// ============================================
model SoftwareCatalog {
  id            String   @id @default(uuid()) @map("id")
  softwareName  String   @map("software_name") @db.VarChar(200)
  version       String   @map("version") @db.VarChar(50)
  publisher     String?  @map("publisher") @db.VarChar(200)
  category      String?  @map("category") @db.VarChar(100) // "OS", "office", "development", "security", "utility"
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  licenses License[]

  @@unique([softwareName, version], map: "uq_software_name_version")
  @@index([softwareName], map: "idx_software_name")
  @@index([category], map: "idx_software_category")
  @@map("software_catalog")
}

// ============================================
// 5. Licenses — Financial and compliance management of software
// ============================================
model License {
  id               String   @id @default(uuid()) @map("id")
  licenseKey       String?  @unique @map("license_key") @db.VarChar(500)
  concurrencyLimit Int      @default(1) @map("concurrency_limit") @db.Integer
  purchaseDate     DateTime? @map("purchase_date") @db.Date
  expiryDate       DateTime? @map("expiry_date") @db.Date
  price            Decimal?  @map("price") @db.Decimal(10, 2)
  softwareId       String   @map("software_id")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  software      SoftwareCatalog     @relation(fields: [softwareId], references: [id], onDelete: Cascade, map: "fk_license_software")
  installations SoftwareInstallation[]

  @@index([softwareId], map: "idx_license_software")
  @@index([expiryDate], map: "idx_license_expiry")
  @@map("licenses")
}

// ============================================
// 6. Software Installations — Compliance control point (M:N)
// Links hardware to licenses — tracks which PC has which licensed software
// ============================================
model SoftwareInstallation {
  id            String   @id @default(uuid()) @map("id")
  hardwareId    String   @map("hardware_id")
  licenseId     String   @map("license_id")
  installedAt   DateTime @default(now()) @map("installed_at") @db.Timestamp(6)
  status        String   @default("active") @map("status") @db.VarChar(20) // "active", "uninstalled", "expired"
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  hardware HardwareAsset @relation(fields: [hardwareId], references: [id], onDelete: Restrict, map: "fk_installation_hardware")
  license  License       @relation(fields: [licenseId], references: [id], onDelete: Restrict, map: "fk_installation_license")

  @@unique([hardwareId, licenseId], map: "uq_installation_hardware_license")
  @@index([hardwareId], map: "idx_installation_hardware")
  @@index([licenseId], map: "idx_installation_license")
  @@index([status], map: "idx_installation_status")
  @@map("software_installations")
}

// ============================================
// 7. Fault History Incidents — Maintenance and repair log
// ============================================
model FaultHistoryIncident {
  id                 String   @id @default(uuid()) @map("id")
  hardwareId         String   @map("hardware_id")
  incidentDescription String  @map("incident_description") @db.Text
  severity           String   @default("medium") @map("severity") @db.VarChar(20) // "low", "medium", "high", "critical"
  status             String   @default("open") @map("status") @db.VarChar(20) // "open", "in_progress", "resolved", "closed"
  reportedAt         DateTime @default(now()) @map("reported_at") @db.Timestamp(6)
  resolvedAt         DateTime? @map("resolved_at") @db.Timestamp(6)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  hardware HardwareAsset @relation(fields: [hardwareId], references: [id], onDelete: Restrict, map: "fk_fault_hardware")

  @@index([hardwareId], map: "idx_fault_hardware")
  @@index([status], map: "idx_fault_status")
  @@index([severity], map: "idx_fault_severity")
  @@map("fault_history_incidents")
}